{
  "version": 2,
  "buildCommand": "pip install -r api/requirements.txt",
  "outputDirectory": "api",
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/main.py"
    }
  ],
  "ignoreCommand": "exit 0"
}
